# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

region         = "us-east-1"
name           = "whoami-lab"
container_port = 8080

# Smallest Fargate size. 256 CPU requires memory in {512, 1024, ...}.
cpu    = 256
memory = 512

log_retention_days = 1

# Tighten to "YOUR.IP.ADD.RESS/32" so the service isn't open to the world.
ingress_cidr = "0.0.0.0/0"
